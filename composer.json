{
    "name": "bitrix/orchestrator",
    "description": "Bitrix Docker Orchestrator",
    "type": "project",
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.2",
        "symfony/console": "^7.0",
        "symfony/process": "^7.0",
        "symfony/http-client": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.1",
        "symfony/test-pack": "^1.2",
        "symfony/filesystem": "^8.0"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
